# ================================================
# VHC API Environment Configuration
# ================================================
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - Core Configuration
# ===========================================

# Node Environment (development | production | test)
NODE_ENV=development

# API Server
PORT=5180
HOST=0.0.0.0

# ===========================================
# REQUIRED - Supabase Configuration
# ===========================================

# Supabase Project URL (from Supabase Dashboard > Settings > API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase Anonymous Key (public, safe for client-side)
SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role Key (secret, server-side only)
# WARNING: Never expose this in client-side code!
SUPABASE_SERVICE_KEY=your-service-key

# ===========================================
# REQUIRED - Encryption
# ===========================================

# Encryption key for sensitive data (32 bytes, hex encoded)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ===========================================
# OPTIONAL - Redis (for job queues)
# ===========================================

# Redis URL for BullMQ job queue
# If not set, some features (notifications, scheduled jobs) will be disabled
# REDIS_URL=redis://localhost:6379

# ===========================================
# OPTIONAL - Twilio SMS (platform default)
# ===========================================

# Platform-default SMS credentials, used for organizations that haven't
# configured their own. When all three are set they take precedence over any
# credentials entered in the admin Platform Settings UI.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+447401059930

# ===========================================
# OPTIONAL - Resend Email (platform default)
# ===========================================

# Platform-default email credentials, used for organizations that haven't
# configured their own. When the API key + from email are set they take
# precedence over any credentials entered in the admin Platform Settings UI.
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=noreply@ollosoft.co.uk
# RESEND_FROM_NAME=VHC Platform

# ===========================================
# OPTIONAL - DVSA MOT History (vehicle lookup)
# ===========================================

# Credentials for the DVSA MOT History API (registration -> vehicle details +
# MOT history on health checks). When all four are set they take precedence over
# any credentials entered in the admin Platform Settings UI. Apply for access at
# https://documentation.history.mot.api.gov.uk/
# DVSA_MOT_CLIENT_ID=
# DVSA_MOT_TENANT_ID=
# DVSA_MOT_CLIENT_SECRET=
# DVSA_MOT_API_KEY=
# Optional kill switch (defaults on when the four vars above are present):
# DVSA_MOT_ENABLED=true

# ===========================================
# OPTIONAL - Postcode -> address lookup (customer modal)
# ===========================================

# Provider-agnostic UK postcode lookup for the "Find address" feature in the
# customer modal. INERT until a key is set (the UI silently falls back to manual
# address entry). When POSTCODE_LOOKUP_API_KEY is set it takes precedence over
# any key in the admin Platform Settings UI.
# Provider: 'getaddress' (default) — apply at https://getaddress.io/
# POSTCODE_LOOKUP_PROVIDER=getaddress
# POSTCODE_LOOKUP_API_KEY=
# Optional kill switch (defaults on when the key above is present):
# POSTCODE_LOOKUP_ENABLED=true

# ===========================================
# OPTIONAL - Automated comms suppression (dev safety)
# ===========================================

# When truthy, AUTOMATED/scheduled comms are skipped: the follow-up sweep,
# scheduled reminders, the daily SMS overview, and the library gap report.
# MANUAL and TEST sends are unaffected — advisor conversation SMS, the Super
# Admin "Test SMS/Email" buttons, the follow-up "send test", "send health check
# to customer", and the manual "send now" digest routes all still send.
# Intended for dev, where the DB is cloned from prod so contact details are real.
# Default OFF. Also forces the follow-up engine into dry-run (see FOLLOW_UP_DRY_RUN).
# SUPPRESS_AUTOMATED_COMMS=true

# ===========================================
# REQUIRED (Production) - App URLs & CORS
# ===========================================

# Comma-separated list of allowed CORS origins (used by HTTP and WebSocket)
# ALLOWED_ORIGINS=https://inspect.ollosoft.io,https://m.inspect.ollosoft.io
ALLOWED_ORIGINS=http://localhost:5181,http://localhost:5182

# Public URL for the web app (used in customer-facing links)
# PUBLIC_APP_URL=https://inspect.ollosoft.io
PUBLIC_APP_URL=http://localhost:5183

# Web dashboard URL (used in notification links)
# WEB_URL=https://inspect.ollosoft.io
WEB_URL=http://localhost:5181

# API public URL (used for self-referencing links)
# API_PUBLIC_URL=https://api.inspect.ollosoft.io

# ===========================================
# OPTIONAL - AI Generation (Anthropic)
# ===========================================

# Anthropic API Key for AI-powered reason generation
# Get your key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# ===========================================
# OPTIONAL - Logging & Monitoring
# ===========================================

# Log level (debug | info | warn | error | fatal)
LOG_LEVEL=info

# Service name for structured logs
SERVICE_NAME=vhc-api

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=
